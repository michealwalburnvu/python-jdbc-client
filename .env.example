# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# SQL Server host (the cname) and database
MSSQL_SERVER=your-sql-host.veteransunited.com
MSSQL_DATABASE=Dqe
MSSQL_PORT=1433

# Windows domain login. Either put the domain in the user (DOMAIN\user)
# or set MSSQL_DOMAIN separately.
MSSQL_USER=DOMAIN\micheal.walburn
# MSSQL_DOMAIN=DOMAIN
MSSQL_PASSWORD=your-windows-password

# Encrypted connection, trusting the server certificate (JDBC equivalent of
# encrypt=true;trustServerCertificate=true). Both default to true.
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERT=true

# Login timeout (seconds)
MSSQL_TIMEOUT=30
